{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Authentication Token Schema",
  "description": "Schema for validating authentication token response",
  "type": "object",
  "required": ["token"],
  "properties": {
    "token": {
      "type": "string",
      "description": "JWT authentication token",
      "minLength": 10
    }
  }
}
