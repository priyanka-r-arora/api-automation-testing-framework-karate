{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cart Schema",
  "description": "Schema for validating cart API responses",
  "type": "object",
  "required": ["id", "userId", "date", "products"],
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the cart"
    },
    "userId": {
      "type": "integer",
      "description": "User ID who owns the cart"
    },
    "date": {
      "type": "string",
      "description": "Cart creation/update date",
      "format": "date-time"
    },
    "products": {
      "type": "array",
      "description": "List of products in the cart",
      "items": {
        "type": "object",
        "required": ["productId", "quantity"],
        "properties": {
          "productId": {
            "type": "integer",
            "minimum": 1
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
