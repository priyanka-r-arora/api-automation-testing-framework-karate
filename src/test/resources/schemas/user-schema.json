{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User Schema",
  "description": "Schema for validating user API responses",
  "type": "object",
  "required": ["id", "email", "username", "password", "name", "address", "phone"],
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the user"
    },
    "email": {
      "type": "string",
      "description": "User email address",
      "format": "email"
    },
    "username": {
      "type": "string",
      "description": "Username",
      "minLength": 1
    },
    "password": {
      "type": "string",
      "description": "User password",
      "minLength": 1
    },
    "name": {
      "type": "object",
      "required": ["firstname", "lastname"],
      "properties": {
        "firstname": {
          "type": "string",
          "minLength": 1
        },
        "lastname": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "address": {
      "type": "object",
      "required": ["city", "street", "number", "zipcode", "geolocation"],
      "properties": {
        "city": {
          "type": "string"
        },
        "street": {
          "type": "string"
        },
        "number": {
          "type": "integer"
        },
        "zipcode": {
          "type": "string"
        },
        "geolocation": {
          "type": "object",
          "required": ["lat", "long"],
          "properties": {
            "lat": {
              "type": "string"
            },
            "long": {
              "type": "string"
            }
          }
        }
      }
    },
    "phone": {
      "type": "string",
      "description": "User phone number"
    }
  }
}
